# ============================================================
# Azure Infrastructure (always required)
# ============================================================

# Azure Document Intelligence (Form Recognizer)
AZURE_AFR_API_KEY=your_azure_afr_api_key_here
AZURE_AFR_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# Azure Cognitive Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your_azure_search_key_here
AZURE_INDEX_NAME=standalone-ece-index

# ============================================================
# LLM Vendor — pick ONE block below and set ACTIVE_LLM_VENDOR
# LiteLLM routes all calls to the configured provider.
# ============================================================

# Active vendor: OPENAI | AZURE | ANTHROPIC | GROQ | OLLAMA
ACTIVE_LLM_VENDOR=OPENAI

# Chat model used by the agent.  LiteLLM accepts provider-prefixed names:
#   OpenAI    → gpt-4o-mini, gpt-4o
#   Azure     → gpt-4o-mini          (azure/ prefix added automatically)
#   Anthropic → claude-3-5-sonnet-20241022
#   Groq      → groq/llama3-70b-8192
#   Ollama    → ollama/llama3
AGENT_CHAT_MODEL=gpt-4o-mini

# Embedding model (used for vector indexing and retrieval).
# Note: Anthropic and Groq have no native embedding API.
#       When using those vendors keep OPENAI_API_KEY set and use an OpenAI
#       embedding model here, or switch to an Ollama embedding model.
EMBEDDING_MODEL=text-embedding-ada-002
VECTOR_SEARCH_DIMENSIONS=1536

# ── Option A: OpenAI ────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Option B: Azure OpenAI ──────────────────────────────────
# ACTIVE_LLM_VENDOR=AZURE
# AZURE_OPENAI_API_KEY=your_azure_openai_key_here
# AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
# AZURE_API_VERSION=2024-02-15-preview

# ── Option C: Anthropic ─────────────────────────────────────
# ACTIVE_LLM_VENDOR=ANTHROPIC
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# AGENT_CHAT_MODEL=claude-3-5-sonnet-20241022
# (keep OPENAI_API_KEY + EMBEDDING_MODEL for embeddings)

# ── Option D: Groq ──────────────────────────────────────────
# ACTIVE_LLM_VENDOR=GROQ
# GROQ_API_KEY=your_groq_api_key_here
# AGENT_CHAT_MODEL=groq/llama3-70b-8192
# (keep OPENAI_API_KEY + EMBEDDING_MODEL for embeddings)

# ── Option E: Ollama (local, no key needed) ─────────────────
# ACTIVE_LLM_VENDOR=OLLAMA
# OLLAMA_API_BASE=http://localhost:11434
# AGENT_CHAT_MODEL=ollama/llama3
# EMBEDDING_MODEL=ollama/nomic-embed-text
# VECTOR_SEARCH_DIMENSIONS=768

# ============================================================
# Chunking Configuration
# ============================================================
CHUNK_SIZE=1200
BUFFER_SIZE=100

# ============================================================
# Processing Configuration
# ============================================================
TIMEOUT_ENABLED=true
AFR_TIMEOUT_SECS=300
MAX_ECE_RETRIALS=3

# ============================================================
# Server Configuration
# ============================================================
HOST=0.0.0.0
PORT=8001

# ============================================================
# PostgreSQL Configuration (Structured Storage)
# ============================================================
# Neon example:
# POSTGRES_URI=postgresql://neondb_owner:npg_xxxxx@ep-curly-sky-xxx.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
POSTGRES_URI=postgresql://user:password@localhost:5432/ece_structured_storage
