# Azure Document Intelligence (Form Recognizer)
AZURE_AFR_API_KEY=your_azure_afr_api_key_here
AZURE_AFR_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# Azure Cognitive Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your_azure_search_key_here
AZURE_INDEX_NAME=standalone-ece-index

# OpenAI (for embeddings)
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-ada-002
VECTOR_SEARCH_DIMENSIONS=1536

# LLM Vendor (OPENAI or AZURE)
ACTIVE_LLM_VENDOR=OPENAI

# Azure OpenAI (if using AZURE vendor)
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_API_VERSION=2024-02-15-preview

# Chunking Configuration
CHUNK_SIZE=1200
BUFFER_SIZE=100

# Processing Configuration
TIMEOUT_ENABLED=true
AFR_TIMEOUT_SECS=300
MAX_ECE_RETRIALS=3

# Server Configuration
HOST=0.0.0.0
PORT=8001

# PostgreSQL Configuration (Structured Storage - Dual Storage Architecture)
# Get your connection string from: https://console.neon.tech/app/projects
# Format: postgresql://user:password@host:port/database?sslmode=require&channel_binding=require
# Example Neon format:
# POSTGRES_URI=postgresql://neondb_owner:npg_xxxxx@ep-curly-sky-xxx.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
POSTGRES_URI=postgresql://user:password@localhost:5432/ece_structured_storage
